; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Jungle Escape: Lost Path"
config/description="A 3D jungle runner adventure game."
run/main_scene="res://scenes/splash/SplashScreen.tscn"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/bg_color=Color(0.07, 0.22, 0.07, 1)
boot_splash/image="res://assets/sprites/ui/splash.png"
config/icon="res://assets/sprites/ui/icon.png"

[autoload]

Constants="*res://scripts/data/Constants.gd"
EventBus="*res://scripts/autoload/EventBus.gd"
SupabaseClient="*res://scripts/autoload/SupabaseClient.gd"
Analytics="*res://scripts/autoload/Analytics.gd"
SaveManager="*res://scripts/autoload/SaveManager.gd"
AdaptiveDifficulty="*res://scripts/autoload/AdaptiveDifficulty.gd"
GameManager="*res://scripts/autoload/GameManager.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=854
window/size/resizable=false
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[input]

swipe_up={
"deadzone": 0.5,
"events": []
}
swipe_down={
"deadzone": 0.5,
"events": []
}
swipe_left={
"deadzone": 0.5,
"events": []
}
swipe_right={
"deadzone": 0.5,
"events": []
}

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
lights_and_shadows/directional_shadow/size=1024
lights_and_shadows/directional_shadow/16_bits=true
anti_aliasing/quality/msaa_3d=0
anti_aliasing/quality/screen_space_aa=0
textures/default_filters/anisotropic_filtering_level=0
camera/depth_of_field/depth_of_field_bokeh_quality=0
environment/glow/upscale_mode=0
environment/screen_space_reflection/roughness_quality=0
